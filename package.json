{
  "name": "moxygen",
  "version": "1.0.0",
  "description": "Doxygen XML to Markdown converter",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "moxygen": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "example": "npm run build && node dist/cli.js --groups --pages --anchors --output=example/doc/api-%s.md example/xml"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sourcey/moxygen.git"
  },
  "keywords": [
    "doxygen",
    "markdown",
    "documentation",
    "generator",
    "api-docs"
  ],
  "author": "Kam Low",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "handlebars": "^4.7.8",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/xml2js": "^0.4.14",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
